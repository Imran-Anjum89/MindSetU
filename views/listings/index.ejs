<% layout("/layouts/boilerplate") %>
<body>

    <style>
        #filters {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
        }

        .filter {
            text-align: center;
            margin-right: 1.5rem;
            margin-top: 1rem;
            opacity: 0.7;
        }

        .filter:hover {
            opacity: 1;
            cursor: pointer;
        }

        .filter div {
            font-size: 1.5rem;
        }

        .filter p {
            font-weight: bold;
        }

        

        /* .listing-card {
            margin-bottom: 1rem;
        } */

        .tax-info {
            display: none;
        }

        .tax-toggle {
            border: 1px solid #50b5d6;
            border-radius: 1rem;
            margin-left: auto;
            height: 3rem;
            padding: 0.5rem;
            display: flex;
            align-items: center;
        }
    </style>


        <!-- <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault"><h6><b>Display total after taxes</b></h6></label>
            </div>
        </div> -->


    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 ">
        <% for(let listing of allListings) { %>
            <a href="/listings/<%= listing._id %>" class="listing-link">
                <div class="card col listing-card" style="width: 20rem;">
                    <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem">
                    <div class="card-img-overlay">verified</div>
                    <div class="card-body">
                        <p class="card-text">
                            <b><%= listing.title %></b>
                            <br>
                            &#8377; <%= listing.price.toLocaleString("en-IN")%> /counselling
                            <!-- <i class="tax-info"> +18% GST</i> -->
                        </p>
                    </div>
                </div>
            </a>
        
        <% } %>
    </div>

</body>

<script>
    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click", () => {
        let taxInfo = document.getElementsByClassName("tax-info");
        for(info of taxInfo) {
            if(taxSwitch.checked) {
                info.style.display = "inline";
            } else {
                info.style.display = "none";
            }
        }
    });
</script>