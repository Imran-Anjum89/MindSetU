            <div class="navbar-nav ms-auto">
                <!-- Send a GET request to the /listings page -->
               <form class="d-flex" action="/listings" method="GET" role="search">
                    <!-- Add name="q" to the input so the server can find the search term -->
                    <input class="form-control me-2 search-inp" type="search" name="q" placeholder="Search Organizations" aria-label="Search"/>
                    <button class="btn search-btn" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search</button>
                </form>
            </div>
            <div class="navbar-nav ms-auto">
