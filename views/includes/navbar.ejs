<style>
    .search-btn {
        background-color: rgb(223, 74, 0);
        color: whitesmoke;
        border-radius: 25px;
        padding: 0 1rem 0 1rem;
    }
    .search-btn:hover {
        background-color: rgb(255, 0, 0);
        color: whitesmoke;
    }
    .search-btn i {
        display: inline;
        margin-right: 0.5rem;
    }
    .search-inp {
        border-radius: 25px;
        padding: 0.5rem 3rem 0.5rem 3rem;
        font-size: 1rem;
    }
    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 5px;
        text-align: center;
    }
    .calendar-header {
        font-weight: bold;
        font-size: 0.8rem;
        color: #6c757d;
    }
    .calendar-day {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        font-size: 0.9rem;
        cursor: pointer;
        border: 2px solid transparent;
    }
    .calendar-day.today { border-color: #0d6efd; }
    .calendar-day.bad { background-color: #f8d7da; color: #58151c; }
    .calendar-day.avg { background-color: #fff3cd; color: #664d03; }
    .calendar-day.good { background-color: #d1e7dd; color: #0f5132; }
</style>

